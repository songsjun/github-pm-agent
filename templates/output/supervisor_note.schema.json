{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["important", "summary", "tags"],
  "properties": {
    "important": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
