{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "should_act",
    "reason",
    "action_type",
    "target",
    "message",
    "labels_to_add",
    "labels_to_remove",
    "action_input",
    "memory_note",
    "issue_title"
  ],
  "properties": {
    "should_act": {
      "type": "boolean"
    },
    "reason": {
      "type": "string"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "comment",
        "label",
        "issue",
        "assign",
        "unassign",
        "review_request",
        "remove_reviewer",
        "edit",
        "milestone",
        "draft",
        "ready_for_review",
        "merge",
        "review_decision",
        "rerun_workflow",
        "cancel_workflow",
        "create_release",
        "create_discussion",
        "update_discussion",
        "project",
        "state",
        "none"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "number"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue",
            "pull_request",
            "discussion",
            "workflow_run",
            "release",
            "project_item",
            "comment",
            "none"
          ]
        },
        "number": {
          "type": "integer"
        }
      }
    },
    "message": {
      "type": "string"
    },
    "needs_human_decision": {
      "type": "boolean"
    },
    "human_decision_reason": {
      "type": "string"
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"]
    },
    "follow_up_after_hours": {
      "type": "integer",
      "minimum": 0
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "options": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": true
          }
        ]
      }
    },
    "labels_to_add": {
      "type": "array",
      "items": { "type": "string" }
    },
    "labels_to_remove": {
      "type": "array",
      "items": { "type": "string" }
    },
    "action_input": {
      "type": "object"
    },
    "memory_note": {
      "type": "string"
    },
    "issue_title": {
      "type": "string"
    }
  }
}
